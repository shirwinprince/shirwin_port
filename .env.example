# Backend (server.js)
RESEND_API_KEY=your_resend_api_key
RECIPIENT_EMAIL=your_inbox@example.com
SENDER_EMAIL=Portfolio Contact <onboarding@resend.dev>
PORT=5000

# Comma-separated list for CORS on deployed API
ALLOWED_ORIGINS=http://localhost:5173,https://shirwinprince.live

# Vercel deployment with api/contact.js uses same-origin /api/contact,
# so no frontend contact API variable is needed.

# Frontend (Vite) - optional LeetCode stats API URL template
# Use {username} placeholder. Example:
# VITE_LEETCODE_STATS_API_BASE_URL=https://your-leetcode-proxy.com/api/u/{username}
VITE_LEETCODE_STATS_API_BASE_URL=
